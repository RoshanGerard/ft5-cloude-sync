{
  "name": "ft5-cloude-sync",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.14.1",
    "pnpm": ">=10"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "package:current-os": "pnpm --filter @ft5/desktop package:win"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "eslint": "10.2.1",
    "eslint-plugin-import-x": "4.16.2",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
