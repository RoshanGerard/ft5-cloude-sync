# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and loaded automatically by electron-vite during dev.
#
# Required for the Google Drive OAuth consent flow (task 11.1, D6):
#   - Register a "Desktop app" OAuth 2.0 client in your GCP project.
#   - Add the client ID and secret here.
#   - For the dev bypass (no browser), also set FT5_DEV_CREDENTIALS=1 and
#     place your pre-obtained credentials at <userData>/dev-credentials.json.
#
# DO NOT commit .env.local — it is in .gitignore.

FT5_GOOGLE_OAUTH_CLIENT_ID=
FT5_GOOGLE_OAUTH_CLIENT_SECRET=
