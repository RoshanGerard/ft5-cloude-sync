{
  "name": "@ft5/fs-sync-service",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main/index.js",
  "types": "src/main/index.ts",
  "exports": {
    ".": {
      "types": "./src/main/index.ts",
      "import": "./dist/main/index.js",
      "default": "./dist/main/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/main/index.js",
    "dev": "pnpm build && node --enable-source-maps dist/main/index.js --dev",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "12.9.0",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@ft5/fs-datasource-engine": "workspace:*",
    "@ft5/ipc-contracts": "workspace:*",
    "@types/better-sqlite3": "7.6.13",
    "vitest": "3.2.4"
  }
}
